<% layout('/layouts/boilerplate')%>

    <body>
        <h3>All Events</h3>
        <div class="carousel-container">
            <div class="carousel-track">
                <div class="carousel-slide current-slide">
                    <img src="images/top1.jpg" alt="John Mayer Concert">
                </div>
                <div class="carousel-slide">
                    <img src="images/top2.jpg" alt="Another Event">
                </div>
                <div class="carousel-slide">
                    <img src="images/top.jpg" alt="Your Next Credit Card Offer">
                </div>
            </div>

            <button class="carousel-button prev">
                <span class="arrow-icon">&#10094;</span> </button>
            <button class="carousel-button next">
                <span class="arrow-icon">&#10095;</span> </button>

            <div class="carousel-nav-dots">
                <button class="dot active"></button>
                <button class="dot"></button>
                <button class="dot"></button>
            </div>
        </div>
        <br> <br>
        <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1">
            <% for(event of allEvents){%>
                <a href="/events/<%=event._id%>" class="event-link">
                    <div class="card col">
                        <img src="<%=event.image.url%>" class="card-img-top" alt="event image" style="height: 26rem;">
                        <div class="card-img-overlay">Hello</div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= event.title%>
                                </b>
                            </p> &nbsp;
                            &#8377;<%= event.ticketPrice.toLocaleString("en-IN")%></br>
                            <%= event.genre%> </br>
                            </p>
                        </div>

                    </div>
                    <%}%>
                </a>
            </div>
    </body>