<% layout('/layouts/boilerplate')%>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3 class="card-title mb-3">
                <%=event.title%>
            </h3>
        </div>
        <div class="card col-6 offset-2 show-card" style="width: 20rem; height: 100vh;">
            <img src="<%=event.image.url%>" class="card-img-top show-img" alt="Event-Image">
            <div class="card-body">
            </div>
        </div>

        <div class="card show-card" style="width: 25rem ; background-color: #eae8e8; height: 29rem;">
            <div class="card-body">
                <br><br> <br> <br>
                <h5 class="card-title">
                    <%=event.title%>
                </h5>
                <br>
                <h6 class="card-subtitle mb-2 text-body-secondary">
                    <%= event.description%>
                </h6>

                <p class="card-text">
                    &#8377;<%= event.ticketPrice.toLocaleString("en-IN")%> <br>
                        <%= event.venue%> <br>
                            <%= event.city%>
                </p>

                <div class="btns">
                    <a href="/events/<%=event._id%>/edit" class="btn btn-dark add-btn">Edit</a>

                    <!-- Ticket Book Button -->
                    <a href="/events/<%=event._id%>/book" class="btn btn-dark add-btn">Tickets</a>
                    <!-- to delete the particular id,i have used or required methodoverride function -->
                    <form method="POST" action="/events/<%=event._id%>?_method=DELETE">
                        <button class="btn btn-dark edit-btn">Delete</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-8 offset-2">
            <h4>Leave a Review</h4>
            <form action="/events/<%=event.id%>/reviews" method="POST">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" min="1" max="5" , name="review[rating]" id="rating" class="form-range">
                </div>
                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea name="review[comment]" id="comment" rows="2" cols="20" class="form-control"
                        required></textarea>
                    <div class="invalid-feedback">
                        Please add comment for reviews!
                    </div>
                </div>
                <button class="btn btn-outline-dark delete-btn mt-3 mb-3 offset-0">Submit</button>
            </form>
            <hr>
            <p><b>All Reviews</b></p>
            <div class="row">
                <% for(review of event.reviews){%>
                    <div class="card col-5 ms-3 mt-3 mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Arya</h5>
                            <p class="card-text">
                                <%=review.comment%>
                            </p>
                            <p class="card-text">
                                <%=review.rating%> stars
                            </p>
                        </div>
                        <form action="/events/<%=event._id%>/reviews/<%=review._id%>?_method=DELETE" , method="POST"
                            class="mb-3">
                            <button class="btn btn-sm btn-dark edit-btn">Delete</button>
                        </form>
                        &nbsp; &nbsp;
                    </div>
                    <%}%>
            </div>
        </div>
    </div>